# Postgres connection string. Defaults below match the bundled docker-compose
# Postgres. When the app runs on the host (dev), use localhost; inside the
# compose network use the service name `postgres`. Point this at any external
# Postgres (incl. a Supabase project's Postgres connection string, with
# sslmode=require) to use that instead of the bundled container.
DATABASE_URL=postgres://owly:owly@localhost:5432/owly
# Credentials for the bundled Postgres container (docker-compose)
POSTGRES_USER=owly
POSTGRES_PASSWORD=owly
POSTGRES_DB=owly

# LLM provider for summaries and digests: "anthropic" (default) or "openai".
# The "openai" provider also works with OpenAI-compatible servers (Ollama,
# OpenRouter, LM Studio, ...) via OPENAI_BASE_URL — best effort.
LLM_PROVIDER=anthropic
# API key for the chosen provider (only the matching one is needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional: base URL for OpenAI-compatible servers, e.g. Ollama:
# OPENAI_BASE_URL=http://localhost:11434/v1
# Model used for the weekly digest.
# Defaults per provider: claude-sonnet-4-6 (anthropic) / gpt-5 (openai)
LLM_MODEL_DIGEST=
# Model used for per-item summaries and preference profile synthesis.
# Defaults per provider: claude-haiku-4-5 (anthropic) / gpt-5-mini (openai)
LLM_MODEL_SUMMARY=
# Owly Post has no built-in authentication (single-user, self-hosted). Secure
# the deployment yourself at the network level: a reverse proxy with HTTP basic
# auth, a VPN, or private networking. Do not expose it directly to the internet.

# Public base URL of your deployment, e.g. https://owly.example.com. Only needed
# for email: it builds the absolute links back to the app in the digest email.
SITE_URL=
# Language for digests and summaries (e.g. nl, en)
DIGEST_LANGUAGE=en
# IANA timezone used for the digest week window and the worker's cron schedules
# (e.g. Europe/Amsterdam); defaults to UTC
DIGEST_TIMEZONE=
# Worker schedules (cron, in DIGEST_TIMEZONE). Defaults: ingest every 6 hours,
# digest Sundays at 17:00 local time.
INGEST_CRON=0 */6 * * *
DIGEST_CRON=0 17 * * 0
# Resend API key; optional, leave empty to disable email delivery
RESEND_API_KEY=
# From address for digest emails; optional
DIGEST_EMAIL_FROM=
# Recipient address for digest emails; optional
DIGEST_EMAIL_TO=
